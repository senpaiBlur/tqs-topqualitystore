<style>
  .no-scrollbar::-webkit-scrollbar { display: none; }
  .no-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }
  .gallery-scroll::-webkit-scrollbar { display: none; }
  .snap-center { scroll-snap-align: center; }
</style>

<section class="py-16 md:py-24 bg-gradient-to-b from-surface to-surface-dim w-full mt-4 pb-20 border-t border-white/60 relative z-10">
    <div class="px-6 md:px-12 mb-12 max-w-7xl mx-auto flex justify-between items-end">
        <div>
            <h3 class="font-headline text-3xl md:text-4xl font-light text-primary uppercase tracking-tighter">{{ section.settings.title }}</h3>
            <p class="font-body text-xs mt-2 tracking-[0.3em] uppercase font-bold text-primary opacity-70">Discover your next favorite.</p>
        </div>
        <div class="hidden md:flex gap-2">
            <button class="w-10 h-10 rounded-full border border-surface-container-high flex items-center justify-center hover:bg-surface-container transition-colors"><span class="material-symbols-outlined text-sm">arrow_back</span></button>
            <button class="w-10 h-10 rounded-full border border-surface-container-high flex items-center justify-center hover:bg-surface-container transition-colors"><span class="material-symbols-outlined text-sm">arrow_forward</span></button>
        </div>
    </div>
    
    <div class="grid grid-cols-2 md:grid-cols-4 gap-4 md:gap-6 px-6 md:px-12 pb-12 w-full max-w-7xl mx-auto">
        <shopify-list-context type="product" query="products" first="6">
            <template>
                <div class="group w-full bg-gradient-to-tr from-surface-container-low to-surface-bright rounded-2xl md:rounded-[2rem] overflow-hidden flex flex-col border border-white/60 shadow-premium transition-all duration-700 transform hover:shadow-floating hover:-translate-y-2 md:hover:-translate-y-3 relative">
                    <a shopify-attr--href="product.onlineStoreUrl" class="block relative group-link flex-grow">
                    <!-- Image -->
                    <div class="w-full aspect-square relative overflow-hidden p-6 hidden-media-container-more">
                        <style>
                          .hidden-media-container-more shopify-media::part(image) {
                            object-fit: contain;
                            filter: drop-shadow(0 20px 30px rgba(220,190,200,0.5));
                          }
                        </style>
                        <shopify-media query="product.selectedOrFirstAvailableVariant.image" class="w-full h-full mix-blend-multiply group-hover:scale-110 transition-transform duration-700"></shopify-media>
                        <!-- SALE Badge -->
                        <div class="absolute top-4 left-4 z-10" shopify-attr--style="product.selectedOrFirstAvailableVariant.compareAtPrice.amount > product.selectedOrFirstAvailableVariant.price.amount ? 'display:block' : 'display:none'">
                            <div class="bg-rose-400/95 backdrop-blur-md text-white font-label text-[8px] md:text-[9px] font-bold uppercase tracking-[0.2em] px-3 py-1 rounded-full shadow-soft-glow">
                                SALE <span shopify-text="Math.round(((product.selectedOrFirstAvailableVariant.compareAtPrice.amount - product.selectedOrFirstAvailableVariant.price.amount) / product.selectedOrFirstAvailableVariant.compareAtPrice.amount) * 100) + '%'"></span>
                            </div>
                        </div>
                    </div>
                
                    <!-- Info -->
                    <div class="p-4 md:px-6 bg-transparent flex-grow flex flex-col justify-end relative z-10 -mt-2">
                        <h4 class="font-headline text-sm font-bold text-primary tracking-wider mb-1 truncate transition-colors">
                            <shopify-data query="product.title"></shopify-data>
                        </h4>
                        <div class="flex flex-col justify-between items-start gap-1">
                            <div class="flex items-center gap-2 flex-wrap mt-1">
                                <span class="font-headline text-base md:text-[17px] font-bold text-primary">
                                    <shopify-money query="product.selectedOrFirstAvailableVariant.price"></shopify-money>
                                </span>
                                <span class="font-body text-[10px] md:text-sm text-outline line-through opacity-60 font-medium" shopify-attr--style="product.selectedOrFirstAvailableVariant.compareAtPrice.amount > 0 ? 'display:inline' : 'display:none'">
                                    <shopify-money query="product.selectedOrFirstAvailableVariant.compareAtPrice"></shopify-money>
                                </span>
                            </div>
                        </div>
                    </div>
                    </a>
                    
                    <!-- Explicit Action Buttons -->
                    <div class="px-4 md:px-6 pb-4 md:pb-6 pt-2 bg-transparent flex gap-2 md:gap-3 w-full relative z-10">
                        <button onclick="document.querySelector('shopify-store').buyNow(event); event.stopPropagation();" shopify-attr--disabled="!product.selectedOrFirstAvailableVariant.availableForSale" class="flex-grow py-3 md:py-3.5 rounded-full bg-primary/95 text-surface-bright font-headline font-bold text-[9px] md:text-[10px] uppercase tracking-[0.2em] hover:opacity-85 flex justify-center items-center shadow-glow hover:shadow-soft-glow transition-all active:scale-95">
                            Buy Now
                        </button>
                        <button onclick="document.getElementById('cart').addLine(event).showModal(); event.stopPropagation();" shopify-attr--disabled="!product.selectedOrFirstAvailableVariant.availableForSale" aria-label="Add to cart" class="flex-shrink-0 w-[38px] h-[38px] md:w-[42px] md:h-[42px] bg-surface-bright border border-outline/30 text-primary rounded-full hover:bg-surface hover:border-primary/50 transition-all flex justify-center items-center shadow-premium hover:shadow-soft-glow">
                            <span class="material-symbols-outlined text-[16px] md:text-[18px] font-light">shopping_bag</span>
                        </button>
                    </div>
                </div>
            </template>
        </shopify-list-context>
    </div>
</section>

{% schema %}
{
  "name": "TQS More Products",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "You May Also Like"
    }
  ],
  "presets": [
    {
      "name": "TQS More Products"
    }
  ]
}
{% endschema %}
