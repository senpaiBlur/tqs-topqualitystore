
{% schema %}
{
  "name": "TQS Collection Page",
  "settings": [
    {
      "type": "header",
      "content": "Navigation"
    },
    {
      "type": "text",
      "id": "brand_text",
      "label": "Brand Name/Logo Text",
      "default": "Top Quality Store (TQS)"
    },
    {
      "type": "header",
      "content": "Aesthetics"
    },
    {
      "type": "text",
      "id": "mobile_subtitle",
      "label": "Header Subtitle",
      "default": "Curated botanical remedies for daily vitality."
    }
  ],
  "presets": [
    {
      "name": "TQS Collection Page"
    }
  ]
}
{% endschema %}

<style>
    /* Fixed Nav Padding Fix */
    .collection-page-body {
        padding-top: 100px;
    }

    /* Headless Components Reset & Image Fixes */
    .custom-product-card shopify-media {
        display: block;
        width: 100%;
        height: 100%;
    }
    
    .custom-product-card shopify-media::part(image) {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }
    
    .custom-product-card shopify-media img {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }

    .image-wrapper {
        transition: transform 0.7s ease;
    }
    
    .custom-product-card:hover .image-wrapper {
        transform: scale(1.05);
    }
    /* Hide shopify internal variant selectors */
    shopify-variant-selector { display: none !important; }

    /* Custom Dropdown Styling */
    .tqs-select-wrapper::after {
        content: '\e5cf';
        font-family: 'Material Symbols Outlined';
        position: absolute;
        right: 12px;
        top: 50%;
        transform: translateY(-50%);
        pointer-events: none;
        font-size: 20px;
        color: #000;
    }
    .tqs-select {
        appearance: none;
        -webkit-appearance: none;
    }
</style>

<!-- TopNavBar (IDENTICAL TO HOME) -->
<nav class="fixed top-0 w-full z-50 bg-[#faf9f9]/80 backdrop-blur-xl shadow-sm text-[#020202] flex flex-col max-w-none transition-all duration-300 border-b border-outline-variant/10">
  <div class="px-6 md:px-12 py-4 flex items-center justify-between">
      <!-- Brand Logo -->
      <a class="text-2xl font-black tracking-tighter text-[#020202] font-headline hover:opacity-70 transition-opacity duration-300 scale-95 active:duration-100" href="/">
          {{ section.settings.brand_text }}
      </a>
      <!-- Navigation Links (Web) -->
      <div class="hidden md:flex space-x-8 items-center font-['Be_Vietnam_Pro'] tracking-tight text-sm uppercase font-semibold">
          <a class="text-[#3c3b3b] hover:text-[#000000] transition-colors hover:opacity-70 transition-opacity duration-300 scale-95 active:duration-100" href="/">Home</a>
          <a class="text-[#000000] border-b-2 border-[#000000] pb-1 hover:opacity-70 transition-opacity duration-300 scale-95 active:duration-100" href="/collections/all">All Products</a>
          <a class="text-[#3c3b3b] hover:text-[#000000] transition-colors hover:opacity-70 transition-opacity duration-300 scale-95 active:duration-100" href="/collections/face-wash">Face Wash</a>
          <a class="text-[#3c3b3b] hover:text-[#000000] transition-colors hover:opacity-70 transition-opacity duration-300 scale-95 active:duration-100" href="/collections/serums">Serums</a>
          <a class="text-[#3c3b3b] hover:text-[#000000] transition-colors hover:opacity-70 transition-opacity duration-300 scale-95 active:duration-100" href="/collections/creams">Creams</a>
      </div>
      <!-- Trailing Icons -->
      <div class="flex items-center space-x-4">
          <a href="/search" aria-label="Search" class="text-[#020202] hover:opacity-70 transition-opacity duration-300 scale-95 active:duration-100 p-2">
              <span class="material-symbols-outlined">search</span>
          </a>
          <a href="/account" aria-label="Profile" class="text-[#020202] hover:opacity-70 transition-opacity duration-300 scale-95 active:duration-100 p-2">
              <span class="material-symbols-outlined">person</span>
          </a>
          <button aria-label="Cart" class="text-[#020202] hover:opacity-70 transition-opacity duration-300 scale-95 active:duration-100 p-2 relative" onclick="document.getElementById('cart').showModal();">
              <span class="material-symbols-outlined">shopping_bag</span>
          </button>
      </div>
  </div>
</nav>

<div class="collection-page-body bg-surface text-on-surface w-full flex flex-col items-center pb-20">
    {% assign active_collection = collection.handle %}
    {% if active_collection == blank %}
        {% assign active_collection = 'all' %}
    {% endif %}

    {% assign is_global = false %}
    {% if active_collection == 'all' %}
        {% assign is_global = true %}
    {% endif %}

    <div class="w-full max-w-7xl mx-auto px-6 md:px-12 mt-8 lg:mt-16">
        <!-- Collection Header -->
        <header class="flex flex-col mb-12">
            <h1 class="font-headline text-5xl md:text-7xl font-black text-black tracking-tighter uppercase leading-none">
                {% if collection.title %}{{ collection.title }}{% else %}The Apothecary{% endif %}
            </h1>
            <p class="font-body text-sm md:text-base text-outline uppercase tracking-[0.2em] mt-4 font-bold opacity-70">
                {{ section.settings.mobile_subtitle }}
            </p>
        </header>

        <!-- Premium Filter System -->
        <div class="flex flex-col md:flex-row items-center gap-6 py-8 border-y border-black/5 mb-12">
            <div class="flex items-center gap-4 w-full md:w-auto">
                <span class="font-label text-xs font-black uppercase tracking-widest">Collection</span>
                <div class="relative flex-grow md:min-w-[240px] tqs-select-wrapper">
                    <select onchange="window.location.href=this.value" class="tqs-select w-full bg-surface-container-low border-0 text-black font-label text-xs font-bold uppercase tracking-widest px-5 py-4 rounded-md cursor-pointer focus:ring-1 focus:ring-black transition-all">
                        <option value="/collections/all">Everything</option>
                        {% for c in collections %}
                            <option value="{{ c.url }}" {% if collection.handle == c.handle %}selected{% endif %}>{{ c.title }}</option>
                        {% endfor %}
                    </select>
                </div>
            </div>

            <div class="flex items-center gap-4 w-full md:w-auto md:ml-auto">
                <span class="font-label text-xs font-black uppercase tracking-widest">Sort</span>
                <div class="relative flex-grow md:min-w-[240px] tqs-select-wrapper">
                    <select onchange="applySort(this.value)" class="tqs-select w-full bg-surface-container-low border-0 text-black font-label text-xs font-bold uppercase tracking-widest px-5 py-4 rounded-md cursor-pointer focus:ring-1 focus:ring-black transition-all">
                        <option value="">Featured</option>
                        <option value="PRICE_ASC">Price: Low to High</option>
                        <option value="PRICE_DESC">Price: High to Low</option>
                        <option value="TITLE_ASC">Alphabetical: A-Z</option>
                        <option value="TITLE_DESC">Alphabetical: Z-A</option>
                    </select>
                </div>
            </div>
        </div>

        <!-- Corrected Grid Wrapper -->
        <div class="grid grid-cols-2 lg:grid-cols-4 xl:grid-cols-5 gap-x-4 md:gap-x-8 gap-y-16">
            {% if is_global %}
                 {% assign list_query = 'products' %}
            {% else %}
                 {% assign list_query = 'collection.products' %}
            {% endif %}

            {% if is_global == false %}
                <shopify-context type="collection" handle="{{ active_collection }}">
                    <template>
            {% endif %}

                <shopify-list-context type="product" query="{{ list_query }}" first="48" style="display: contents;">
                    <template>
                        <article class="flex flex-col group custom-product-card">
                            <a shopify-attr--href="product.onlineStoreUrl" class="block flex-grow">
                                <div class="aspect-[4/5] relative w-full bg-surface-container-highest rounded-2xl overflow-hidden shadow-sm transition-shadow hover:shadow-xl">
                                    <div class="image-wrapper w-full h-full">
                                        <shopify-media query="product.selectedOrFirstAvailableVariant.image"></shopify-media>
                                    </div>
                                    
                                    <!-- Badges -->
                                    <div class="absolute top-4 left-4 flex flex-col gap-2">
                                        <div class="bg-black text-white font-label text-[10px] font-black uppercase tracking-widest px-3 py-1.5 rounded-sm">
                                            <shopify-data query="product.vendor"></shopify-data>
                                        </div>
                                        <div class="bg-red-600 text-white font-label text-[10px] font-black uppercase tracking-widest px-3 py-1.5 rounded-sm" 
                                             shopify-attr--style="product.selectedOrFirstAvailableVariant.compareAtPrice.amount > product.selectedOrFirstAvailableVariant.price.amount ? 'display:block' : 'display:none'">
                                            SAVE <span shopify-text="Math.round(((product.selectedOrFirstAvailableVariant.compareAtPrice.amount - product.selectedOrFirstAvailableVariant.price.amount) / product.selectedOrFirstAvailableVariant.compareAtPrice.amount) * 100) + '%'"></span>
                                        </div>
                                    </div>
                                </div>
                                
                                <div class="mt-6 flex flex-col gap-2">
                                    <h3 class="font-headline text-base font-bold text-black uppercase tracking-tight line-clamp-1 group-hover:text-primary transition-colors">
                                        <shopify-data query="product.title"></shopify-data>
                                    </h3>
                                    <div class="flex items-center gap-3">
                                        <span class="font-headline text-xl font-black text-black">
                                            <shopify-money query="product.selectedOrFirstAvailableVariant.price"></shopify-money>
                                        </span>
                                        <span class="font-body text-sm text-outline line-through opacity-40 font-medium" shopify-attr--style="product.selectedOrFirstAvailableVariant.compareAtPrice.amount > 0 ? 'display:inline' : 'display:none'">
                                            <shopify-money query="product.selectedOrFirstAvailableVariant.compareAtPrice"></shopify-money>
                                        </span>
                                    </div>
                                </div>
                            </a>

                            <div class="mt-6 flex gap-3">
                                <button onclick="document.querySelector('shopify-store').buyNow(event); event.preventDefault(); event.stopPropagation();" shopify-attr--disabled="!product.selectedOrFirstAvailableVariant.availableForSale" class="flex-grow bg-black text-white py-4 rounded-full font-headline font-black text-[11px] uppercase tracking-[0.2em] hover:bg-zinc-800 transition-all active:scale-95 shadow-md">
                                    Buy Now
                                </button>
                                <button onclick="document.getElementById('cart').addLine(event).showModal(); event.preventDefault(); event.stopPropagation();" shopify-attr--disabled="!product.selectedOrFirstAvailableVariant.availableForSale" class="w-14 h-14 border-2 border-black text-black rounded-full flex items-center justify-center hover:bg-black text-white hover:text-white transition-all">
                                    <span class="material-symbols-outlined text-[24px]">shopping_bag</span>
                                </button>
                            </div>
                        </article>
                    </template>
                    <div shopify-loading-placeholder class="col-span-full py-60 flex flex-col items-center">
                        <div class="w-12 h-12 border-4 border-black border-t-transparent rounded-full animate-spin"></div>
                        <p class="font-label text-xs uppercase tracking-[0.4em] font-black mt-8">Restocking...</p>
                    </div>
                </shopify-list-context>

            {% if is_global == false %}
                    </template>
                </shopify-context>
            {% endif %}
        </div>
    </div>
</div>

<script>
    function applySort(value) {
        const listContext = document.querySelector('shopify-list-context');
        if (!listContext) return;
        if (!value) {
            listContext.removeAttribute('sort-key');
            listContext.removeAttribute('reverse');
            return;
        }
        const parts = value.split('_');
        const isDesc = parts[parts.length - 1] === 'DESC';
        const sortKey = parts.slice(0, -1).join('_');
        listContext.setAttribute('sort-key', sortKey);
        if(isDesc) listContext.setAttribute('reverse', 'true');
        else listContext.removeAttribute('reverse');
    }
</script>
