
{% schema %}
{
  "name": "TQS Collection Page",
  "settings": [
    {
      "type": "header",
      "content": "Navigation"
    },
    {
      "type": "text",
      "id": "brand_text",
      "label": "Brand Name/Logo Text",
      "default": "Top Quality Store (TQS)"
    },
    {
      "type": "link_list",
      "id": "main_menu",
      "label": "Header Menu",
      "default": "main-menu"
    },
    {
      "type": "link_list",
      "id": "footer_menu",
      "label": "Footer Menu",
      "default": "footer"
    },
    {
      "type": "header",
      "content": "Aesthetics"
    },
    {
      "type": "text",
      "id": "mobile_subtitle",
      "label": "Header Subtitle",
      "default": "Curated botanical remedies for daily vitality."
    }
  ],
  "presets": [
    {
      "name": "TQS Collection Page"
    }
  ]
}
{% endschema %}

<style>
    /* Fixed Nav Padding Fix */
    .collection-page-body {
        padding-top: 100px;
    }

    /* Headless Components Reset & Image Fixes */
    .custom-product-card shopify-media {
        display: block;
        width: 100%;
        height: 100%;
    }
    
    .custom-product-card shopify-media::part(image) {
        width: 100%;
        height: 100%;
        object-fit: contain;
        filter: drop-shadow(0 20px 30px rgba(220,190,200,0.5));
    }
    
    .custom-product-card shopify-media img {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }

    .image-wrapper {
        transition: transform 0.7s cubic-bezier(0.33, 1, 0.68, 1);
    }
    
    .custom-product-card:hover .image-wrapper {
        transform: scale(1.1) translateY(-8px);
    }
    /* Hide shopify internal variant selectors */
    shopify-variant-selector { display: none !important; }

    /* Custom Dropdown Styling */
    .tqs-select-wrapper::after {
        content: '\e5cf';
        font-family: 'Material Symbols Outlined';
        position: absolute;
        right: 12px;
        top: 50%;
        transform: translateY(-50%);
        pointer-events: none;
        font-size: 20px;
        color: #000;
        opacity: 0.5;
    }
    .tqs-select {
        appearance: none;
        -webkit-appearance: none;
    }

    /* Mobile Menu Drawer */
    #mobile-menu-drawer.active {
        transform: translateX(0);
    }
</style>

<!-- TopNavBar (Dynamic) -->
<nav class="fixed top-0 w-full z-50 bg-surface-bright/70 backdrop-blur-2xl shadow-premium border-b border-white/20 text-primary flex flex-col max-w-none transition-all duration-500">
  <div class="px-6 md:px-12 py-4 flex items-center justify-between">
      <!-- Brand Logo -->
      <a class="text-2xl font-black tracking-tighter text-primary font-headline hover:opacity-80 transition-opacity" href="/">
          {{ section.settings.brand_text }}
      </a>
      
      <!-- Dynamic Navigation Links (Web) -->
      <div class="hidden lg:flex space-x-8 items-center font-label tracking-[0.15em] text-[10px] uppercase font-bold">
          {% for link in linklists[section.settings.main_menu].links %}
            <a class="{% if link.active %}text-primary border-b border-primary pb-1{% else %}text-outline hover:text-primary{% endif %} transition-all" href="{{ link.url }}">{{ link.title }}</a>
          {% endfor %}
      </div>

      <!-- Trailing Icons -->
      <div class="flex items-center space-x-2 md:space-x-4 text-primary">
          <a href="/account" class="p-2 hover:opacity-70 transition-opacity">
              <span class="material-symbols-outlined text-[24px] font-light">person</span>
          </a>
          <button class="p-2 relative hover:opacity-70 transition-opacity" onclick="document.getElementById('cart').showModal();">
              <span class="material-symbols-outlined text-[24px] font-light">shopping_bag</span>
          </button>
          
          <!-- Mobile Toggle -->
          <button class="lg:hidden p-2" onclick="document.getElementById('mobile-menu-drawer').classList.toggle('active')">
              <span class="material-symbols-outlined text-[24px] font-light">menu</span>
          </button>
      </div>
  </div>
</nav>

<!-- Mobile Menu Drawer Overlay -->
<div id="mobile-menu-drawer" class="fixed inset-y-0 left-0 w-80 bg-white z-[60] shadow-2xl p-8 transform -translate-x-full transition-transform duration-500 ease-in-out lg:hidden">
    <div class="flex justify-between items-center mb-12">
        <span class="text-xl font-black tracking-tighter">{{ section.settings.brand_text }}</span>
        <button onclick="document.getElementById('mobile-menu-drawer').classList.remove('active')">
            <span class="material-symbols-outlined">close</span>
        </button>
    </div>
    <div class="flex flex-col space-y-6">
        {% for link in linklists[section.settings.main_menu].links %}
            <a class="font-headline text-2xl font-bold tracking-tighter uppercase" href="{{ link.url }}">{{ link.title }}</a>
        {% endfor %}
    </div>
</div>

<div class="collection-page-body bg-white text-on-surface w-full flex flex-col items-center">
    {% assign active_collection = collection.handle %}
    {% if active_collection == blank %}{% assign active_collection = 'all' %}{% endif %}
    {% assign is_global = false %}
    {% if active_collection == 'all' %}{% assign is_global = true %}{% endif %}

    <div class="w-full max-w-7xl mx-auto px-6 md:px-12 mt-8 lg:mt-16">
        <!-- Header -->
        <header class="flex flex-col mb-12">
            <h1 class="font-headline text-4xl md:text-6xl font-light text-primary tracking-tighter uppercase leading-none">
                {% if collection.title %}{{ collection.title }}{% else %}The Apothecary{% endif %}
            </h1>
            <p class="font-body text-xs md:text-sm text-primary uppercase tracking-[0.3em] mt-6 font-bold opacity-70">
                {{ section.settings.mobile_subtitle }}
            </p>
        </header>

        <!-- Premium Filter Bar -->
        <div class="flex flex-col lg:flex-row items-start lg:items-center gap-10 py-10 border-y border-outline/10 mb-16 w-full">
            <!-- Category Filter -->
            <div class="flex flex-col gap-3 w-full lg:w-auto">
                <span class="font-label text-[10px] font-black uppercase tracking-[0.2em] text-outline ml-1">Browse Category</span>
                <div class="relative min-w-[240px] tqs-select-wrapper">
                    <select onchange="window.location.href=this.value" class="tqs-select w-full bg-white border border-outline/10 text-black font-headline text-[12px] font-bold uppercase tracking-widest px-6 py-4 rounded-xl cursor-pointer focus:ring-1 focus:ring-primary focus:border-primary transition-all hover:border-primary/30">
                        <option value="/collections/all">All Products</option>
                        {% for c in collections %}
                            {% if c.products_count > 0 %}
                                <option value="{{ c.url }}" {% if collection.handle == c.handle %}selected{% endif %}>{{ c.title }}</option>
                            {% endif %}
                        {% endfor %}
                    </select>
                </div>
            </div>

            <!-- Price Filter -->
            <div class="flex flex-col gap-3 w-full lg:w-auto">
                <span class="font-label text-[10px] font-black uppercase tracking-[0.2em] text-outline ml-1">Price Range</span>
                <div class="flex items-center gap-2">
                    <div class="relative">
                        <span class="absolute left-4 top-1/2 -translate-y-1/2 text-[10px] font-bold text-outline">₹</span>
                        <input type="number" id="min-price" placeholder="Min" class="w-24 bg-white border border-outline/10 text-black font-headline text-[12px] font-bold px-8 py-4 rounded-xl focus:ring-1 focus:ring-primary" onchange="applyPriceFilter()">
                    </div>
                    <span class="text-outline font-headline text-[10px] uppercase font-bold">to</span>
                    <div class="relative">
                        <span class="absolute left-4 top-1/2 -translate-y-1/2 text-[10px] font-bold text-outline">₹</span>
                        <input type="number" id="max-price" placeholder="Max" class="w-24 bg-white border border-outline/10 text-black font-headline text-[12px] font-bold px-8 py-4 rounded-xl focus:ring-1 focus:ring-primary" onchange="applyPriceFilter()">
                    </div>
                </div>
            </div>

            <!-- Sort Filter -->
            <div class="flex flex-col gap-3 w-full lg:w-auto lg:ml-auto">
                <span class="font-label text-[10px] font-black uppercase tracking-[0.2em] text-outline ml-1">Sort Order</span>
                <div class="relative min-w-[240px] tqs-select-wrapper">
                    <select onchange="applySort(this.value)" class="tqs-select w-full bg-white border border-outline/10 text-black font-headline text-[12px] font-bold uppercase tracking-widest px-6 py-4 rounded-xl cursor-pointer focus:ring-1 focus:ring-primary focus:border-primary transition-all hover:border-primary/30">
                        <option value="">Default Selection</option>
                        <option value="PRICE_ASC">Price: Low to High</option>
                        <option value="PRICE_DESC">Price: High to Low</option>
                        <option value="TITLE_ASC">Alphabetical: A-Z</option>
                        <option value="TITLE_DESC">Alphabetical: Z-A</option>
                    </select>
                </div>
            </div>
        </div>

        <!-- Grid -->
        <div class="grid grid-cols-2 lg:grid-cols-4 xl:grid-cols-5 gap-x-6 md:gap-x-10 gap-y-20 mb-32">
            {% assign list_query = 'products' %}
            {% if is_global == false %}{% assign list_query = 'collection.products' %}{% endif %}

            {% if is_global == false %}
                <shopify-context type="collection" handle="{{ active_collection }}">
                    <template>
            {% endif %}

                <shopify-list-context type="product" query="{{ list_query }}" first="48" style="display: contents;">
                    <template>
                        <article class="flex flex-col group custom-product-card">
                            <a shopify-attr--href="product.onlineStoreUrl" class="block flex-grow">
                                <div class="aspect-square relative w-full bg-surface rounded-[2rem] overflow-hidden shadow-premium transition-all duration-700 ease-out group-hover:shadow-floating group-hover:-translate-y-3 border border-outline/5">
                                    <div class="image-wrapper w-full h-full p-2 mix-blend-multiply">
                                        <shopify-media query="product.selectedOrFirstAvailableVariant.image"></shopify-media>
                                    </div>
                                    
                                    <div class="absolute top-5 left-5 flex flex-col gap-2 z-10">
                                        <div class="bg-rose-500 text-white font-headline text-[10px] font-black tracking-widest px-3 py-1 rounded-lg shadow-lg" 
                                             shopify-attr--style="product.selectedOrFirstAvailableVariant.compareAtPrice.amount > product.selectedOrFirstAvailableVariant.price.amount ? 'display:inline-block' : 'display:none'">
                                            <span shopify-text="Math.round(((product.selectedOrFirstAvailableVariant.compareAtPrice.amount - product.selectedOrFirstAvailableVariant.price.amount) / product.selectedOrFirstAvailableVariant.compareAtPrice.amount) * 100) + '% OFF'"></span>
                                        </div>
                                    </div>
                                </div>
                                
                                <div class="mt-8 flex flex-col gap-2 px-2">
                                    <h3 class="font-headline text-sm font-bold text-primary uppercase tracking-wider line-clamp-1 transition-colors">
                                        <shopify-data query="product.title"></shopify-data>
                                    </h3>
                                    <div class="flex items-center gap-3">
                                        <span class="font-headline text-lg font-bold text-primary">
                                            <shopify-money query="product.selectedOrFirstAvailableVariant.price"></shopify-money>
                                        </span>
                                        <span class="font-body text-sm text-outline line-through opacity-40 font-medium" shopify-attr--style="product.selectedOrFirstAvailableVariant.compareAtPrice.amount > 0 ? 'display:inline' : 'display:none'">
                                            <shopify-money query="product.selectedOrFirstAvailableVariant.compareAtPrice"></shopify-money>
                                        </span>
                                    </div>
                                </div>
                            </a>

                            <div class="mt-6 flex gap-3 px-2">
                                <button onclick="document.querySelector('shopify-store').buyNow(event); event.preventDefault(); event.stopPropagation();" shopify-attr--disabled="!product.selectedOrFirstAvailableVariant.availableForSale" class="flex-grow bg-primary/95 text-surface-bright py-4 rounded-full font-headline font-bold text-[10px] uppercase tracking-[0.2em] hover:opacity-85 transition-all shadow-glow hover:shadow-soft-glow active:scale-95">
                                    Buy Now
                                </button>
                                <button onclick="document.getElementById('cart').addLine(event).showModal(); event.preventDefault(); event.stopPropagation();" shopify-attr--disabled="!product.selectedOrFirstAvailableVariant.availableForSale" class="w-12 h-12 border border-outline/30 bg-surface-bright text-primary rounded-full flex items-center justify-center hover:border-primary/50 hover:bg-surface transition-all shadow-premium hover:shadow-soft-glow cursor-pointer">
                                    <span class="material-symbols-outlined text-[20px] font-light">shopping_bag</span>
                                </button>
                            </div>
                        </article>
                    </template>
                    <div shopify-loading-placeholder class="col-span-full py-60 flex flex-col items-center">
                        <div class="w-16 h-16 border-4 border-primary border-t-transparent rounded-full animate-spin shadow-glow"></div>
                        <p class="font-label text-xs uppercase tracking-[0.5em] font-bold mt-12 text-primary opacity-60">Restocking Collection...</p>
                    </div>
                </shopify-list-context>

            {% if is_global == false %}
                    </template>
                </shopify-context>
            {% endif %}
        </div>
    </div>
</div>

<!-- Dynamic Footer -->
<footer class="bg-white text-primary w-full pt-32 pb-16 border-t border-outline/10">
    <div class="max-w-7xl mx-auto px-6 md:px-12 grid grid-cols-1 md:grid-cols-12 gap-16">
        <div class="md:col-span-4 space-y-6">
            <h4 class="text-2xl font-black tracking-tighter uppercase font-headline">{{ section.settings.brand_text }}</h4>
            <p class="font-body text-sm text-outline leading-relaxed max-w-sm">
                Curated botanical remedies for the modern canvas. Minimalist science, maximalist results.
            </p>
        </div>
        
        <div class="md:col-span-8 grid grid-cols-2 md:grid-cols-3 gap-12">
            <div class="flex flex-col space-y-5">
                <span class="font-label text-xs font-bold uppercase tracking-[0.2em] text-outline mb-2">Explore</span>
                {% for link in linklists[section.settings.main_menu].links %}
                    {% assign link_title_lower = link.title | downcase %}
                    {% unless link_title_lower contains 'search' %}
                        <a class="font-label text-sm hover:text-outline transition-colors" href="{{ link.url }}">{{ link.title }}</a>
                    {% endunless %}
                {% endfor %}
            </div>

            <div class="flex flex-col space-y-5">
                <span class="font-label text-xs font-bold uppercase tracking-[0.2em] text-outline mb-2">Connect</span>
                <a class="font-label text-sm hover:text-outline transition-colors" href="#">Instagram</a>
                <a class="font-label text-sm hover:text-outline transition-colors" href="#">WhatsApp</a>
            </div>
        </div>
    </div>
</footer>

<script>
    document.addEventListener("DOMContentLoaded", () => {
        const urlParams = new URLSearchParams(window.location.search);
        if (urlParams.has('filter.v.price.gte')) {
            document.getElementById('min-price').value = urlParams.get('filter.v.price.gte');
        }
        if (urlParams.has('filter.v.price.lte')) {
            document.getElementById('max-price').value = urlParams.get('filter.v.price.lte');
        }
    });

    function applyPriceFilter() {
        const min = document.getElementById('min-price').value;
        const max = document.getElementById('max-price').value;
        const url = new URL(window.location.href);
        
        if (min) url.searchParams.set('filter.v.price.gte', min);
        else url.searchParams.delete('filter.v.price.gte');
        
        if (max) url.searchParams.set('filter.v.price.lte', max);
        else url.searchParams.delete('filter.v.price.lte');
        
        window.location.href = url.toString();
    }

    function applySort(value) {
        const listContext = document.querySelector('shopify-list-context');
        if (!listContext) return;
        if (!value) {
            listContext.removeAttribute('sort-key');
            listContext.removeAttribute('reverse');
            return;
        }
        const parts = value.split('_');
        const isDesc = parts[parts.length - 1] === 'DESC';
        const sortKey = parts.slice(0, -1).join('_');
        listContext.setAttribute('sort-key', sortKey);
        if(isDesc) listContext.setAttribute('reverse', 'true');
        else listContext.removeAttribute('reverse');
    }
</script>
