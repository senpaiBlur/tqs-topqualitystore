  <script>
      // Tab Toggle Logic
      document.addEventListener("DOMContentLoaded", () => {
          const tabBest = document.getElementById('tab-bestsellers');
          const tabNew = document.getElementById('tab-new');
          const gridBest = document.getElementById('grid-bestsellers');
          const gridNew = document.getElementById('grid-new');

          const switchTab = (activeTab, inactiveTab, activeGrid, inactiveGrid) => {
              // Styling
              activeTab.classList.add('text-primary', 'border-b-2', 'border-primary');
              activeTab.classList.remove('text-outline');
              inactiveTab.classList.remove('text-primary', 'border-b-2', 'border-primary');
              inactiveTab.classList.add('text-outline');

              // Grids Toggle with fade
              inactiveGrid.classList.remove('opacity-100');
              inactiveGrid.classList.add('opacity-0');
              setTimeout(() => {
                  inactiveGrid.classList.add('hidden');
                  inactiveGrid.classList.remove('grid');
                  
                  activeGrid.classList.remove('hidden');
                  activeGrid.classList.add('grid');
                  setTimeout(() => {
                      activeGrid.classList.remove('opacity-0');
                      activeGrid.classList.add('opacity-100');
                  }, 50);
              }, 400); // 400ms CSS fade margin
          };

          tabBest.addEventListener('click', () => switchTab(tabBest, tabNew, gridBest, gridNew));
          tabNew.addEventListener('click', () => switchTab(tabNew, tabBest, gridNew, gridBest));
      });
  </script>

