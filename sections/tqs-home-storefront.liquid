<style>
  shopify-media img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      transition: transform 700ms;
  }
  .group:hover shopify-media img {
      transform: scale(1.05);
  }
  /* Fixed Nav Padding Fix */
  .home-page-body {
      padding-top: 80px;
  }
  /* Mobile Menu Drawer */
  #mobile-menu-drawer.active {
      transform: translateX(0);
  }
</style>

<!-- TopNavBar (Dynamic) -->
<nav class="fixed top-0 w-full z-50 bg-[#faf9f9]/80 backdrop-blur-xl shadow-sm border-b border-black/5 text-black flex flex-col max-w-none transition-all duration-300">
  <div class="px-6 md:px-12 py-4 flex items-center justify-between">
      <!-- Brand Logo -->
      <a class="text-2xl font-black tracking-tighter text-black font-headline hover:opacity-70 transition-opacity" href="/">
          {{ section.settings.brand_text | default: "Top Quality Store (TQS)" }}
      </a>
      
      <!-- Dynamic Navigation Links (Web) -->
      <div class="hidden lg:flex space-x-8 items-center font-label tracking-tight text-[11px] uppercase font-black">
          {% for link in linklists[section.settings.main_menu].links %}
            <a class="{% if link.active %}text-black border-b-2 border-black pb-1{% else %}text-outline hover:text-black{% endif %} transition-all" href="{{ link.url }}">{{ link.title }}</a>
          {% endfor %}
      </div>

      <!-- Trailing Icons -->
      <div class="flex items-center space-x-2 md:space-x-4">
          <a href="/account" class="text-black p-2 hover:opacity-70 transition-opacity">
              <span class="material-symbols-outlined text-[22px]">person</span>
          </a>
          <button class="text-black p-2 relative hover:opacity-70 transition-opacity" onclick="document.getElementById('cart').showModal();">
              <span class="material-symbols-outlined text-[22px]">shopping_bag</span>
          </button>
          
          <!-- Mobile Toggle -->
          <button class="lg:hidden text-black p-2" onclick="document.getElementById('mobile-menu-drawer').classList.toggle('active')">
              <span class="material-symbols-outlined text-[22px]">menu</span>
          </button>
      </div>
  </div>
</nav>

<!-- Mobile Menu Drawer Overlay -->
<div id="mobile-menu-drawer" class="fixed inset-y-0 left-0 w-80 bg-white z-[60] shadow-2xl p-8 transform -translate-x-full transition-transform duration-500 ease-in-out lg:hidden">
    <div class="flex justify-between items-center mb-12">
        <span class="text-xl font-black tracking-tighter">{{ section.settings.brand_text | default: "TQS" }}</span>
        <button onclick="document.getElementById('mobile-menu-drawer').classList.remove('active')">
            <span class="material-symbols-outlined">close</span>
        </button>
    </div>
    <div class="flex flex-col space-y-6">
        {% for link in linklists[section.settings.main_menu].links %}
            <a class="font-headline text-2xl font-bold tracking-tighter uppercase" href="{{ link.url }}">{{ link.title }}</a>
        {% endfor %}
    </div>
</div>

<!-- Main Content -->
<main class="home-page-body pb-32">
  
  <!-- Hero Section -->
  <div id="hero-slider-container">
    <shopify-list-context type="product" query="products" first="4">
      <template>
          <section class="hero-slide hidden flex-col lg:flex-row bg-surface px-6 md:px-12 lg:px-24 py-12 gap-12 lg:gap-24 relative overflow-hidden transition-opacity duration-1000 opacity-0" style="min-height: 800px;">
              <!-- Left: Image -->
              <div class="w-full lg:w-1/2 flex items-center justify-center relative">
                  <div class="absolute inset-0 bg-surface-container-low rounded-[3rem] transform -rotate-3 scale-105 z-0 transition-transform duration-700 hover:rotate-0"></div>
                  <div class="relative z-10 w-full max-w-md h-auto rounded-3xl overflow-hidden shadow-2xl aspect-[3/4]">
                    <shopify-media query="product.selectedOrFirstAvailableVariant.image"></shopify-media>
                  </div>
              </div>
              
              <!-- Right: Content -->
              <div class="w-full lg:w-1/2 flex flex-col justify-center space-y-8 z-10">
                  <div class="space-y-6">
                      <p class="font-label text-sm uppercase font-black tracking-[0.3em] text-outline">
                          <shopify-data query="product.vendor"></shopify-data>
                      </p>
                      <h1 class="font-headline text-5xl md:text-7xl lg:text-8xl font-black text-black leading-none tracking-tighter uppercase">
                          <shopify-data query="product.title"></shopify-data>
                      </h1>
                      <p class="font-body text-xl text-on-surface-variant max-w-lg leading-relaxed line-clamp-3 opacity-70">
                          <shopify-data query="product.description"></shopify-data>
                      </p>
                  </div>
                  
                  <div class="flex flex-wrap items-center gap-4">
                      <button onclick="document.querySelector('shopify-store').buyNow(event)" shopify-attr--disabled="!product.selectedOrFirstAvailableVariant.availableForSale" class="inline-flex items-center justify-center px-10 py-5 bg-black text-white font-headline font-black text-xs uppercase tracking-[0.2em] rounded-full hover:bg-zinc-800 transition-all shadow-xl active:scale-95">
                          Buy Now
                      </button>
                      <button onclick="document.getElementById('cart').addLine(event).showModal();" shopify-attr--disabled="!product.selectedOrFirstAvailableVariant.availableForSale" class="inline-flex items-center justify-center px-6 py-5 bg-white border-2 border-black text-black font-headline font-black text-xs uppercase tracking-[0.2em] rounded-full hover:bg-black hover:text-white transition-all gap-3 shadow-lg">
                          Add to Cart
                      </button>
                      <a href="https://wa.me/918506934982?text=I'm%20interested" target="_blank" class="inline-flex items-center justify-center px-6 py-5 bg-[#25D366] text-white font-headline font-black text-xs uppercase tracking-[0.1em] rounded-full hover:opacity-90 transition-all gap-2 shadow-xl">
                          WhatsApp
                      </a>
                  </div>
              </div>
          </section>
      </template>
    </shopify-list-context>
  </div>

  <script>
      document.addEventListener("DOMContentLoaded", () => {
         let initSlider = setInterval(() => {
            const slides = document.querySelectorAll('.hero-slide');
            if(slides.length > 0) {
               slides.forEach(s => { s.style.display = 'none'; });
               let currentIndex = 0;
               const showSlide = (index) => {
                   slides[index].style.display = 'flex';
                   setTimeout(() => {
                       slides[index].classList.remove('opacity-0');
                       slides[index].classList.add('opacity-100');
                   }, 50);
               };
               const hideSlide = (index, callback) => {
                   slides[index].classList.remove('opacity-100');
                   slides[index].classList.add('opacity-0');
                   setTimeout(() => {
                       slides[index].style.display = 'none';
                       if (callback) callback();
                   }, 1000); 
               };
               showSlide(currentIndex);
               setInterval(() => {
                   hideSlide(currentIndex, () => {
                       currentIndex = (currentIndex + 1) % slides.length;
                       showSlide(currentIndex);
                   });
               }, 7000);
               clearInterval(initSlider);
            }
         }, 1000);
      });
  </script>

  <!-- Product Grid -->
  <section class="py-32 px-6 md:px-12 lg:px-24 bg-surface">
      <div class="max-w-7xl mx-auto flex flex-col space-y-24">
          <div class="text-center md:text-left">
              <h2 class="font-headline text-5xl md:text-7xl font-black text-black tracking-tighter uppercase leading-none">
                  Honest Formulations.
              </h2>
          </div>

          <div id="grid-main" class="grid grid-cols-2 lg:grid-cols-4 gap-x-6 md:gap-x-10 gap-y-20">
              <shopify-list-context type="product" query="products" first="12">
                  <template>
                      <div class="group flex flex-col">
                          <div class="relative aspect-[4/5] bg-surface-container-low rounded-3xl overflow-hidden shadow-sm transition-all duration-500 group-hover:shadow-2xl group-hover:-translate-y-2">
                              <a shopify-attr--href="product.onlineStoreUrl" class="block w-full h-full">
                                <shopify-media query="product.selectedOrFirstAvailableVariant.image"></shopify-media>
                              </a>
                              <div class="absolute top-5 left-5 flex flex-col gap-2">
                                  <span class="bg-black text-white px-3 py-1.5 rounded-sm font-label text-[9px] uppercase font-black tracking-widest shadow-xl">
                                      <shopify-data query="product.vendor"></shopify-data>
                                  </span>
                                  <div class="bg-red-600 text-white px-3 py-1.5 rounded-sm font-label text-[9px] uppercase font-black tracking-widest shadow-xl"
                                       shopify-attr--style="product.selectedOrFirstAvailableVariant.compareAtPrice.amount > product.selectedOrFirstAvailableVariant.price.amount ? 'display:block' : 'display:none'">
                                    SAVE <span shopify-text="Math.round(((product.selectedOrFirstAvailableVariant.compareAtPrice.amount - product.selectedOrFirstAvailableVariant.price.amount) / product.selectedOrFirstAvailableVariant.compareAtPrice.amount) * 100) + '%'"></span>
                                  </div>
                              </div>
                          </div>
                          <div class="mt-8 flex flex-col px-1">
                              <h3 class="font-headline text-base font-bold text-black uppercase tracking-tight truncate group-hover:text-primary transition-colors">
                                  <shopify-data query="product.title"></shopify-data>
                              </h3>
                              <div class="flex items-center gap-3 mt-1">
                                  <span class="font-headline text-xl font-black text-black">
                                      <shopify-money query="product.selectedOrFirstAvailableVariant.price"></shopify-money>
                                  </span>
                                  <span class="font-body text-sm text-outline line-through opacity-40 font-medium" shopify-attr--style="product.selectedOrFirstAvailableVariant.compareAtPrice.amount > 0 ? 'display:inline' : 'display:none'">
                                      <shopify-money query="product.selectedOrFirstAvailableVariant.compareAtPrice"></shopify-money>
                                  </span>
                              </div>
                          </div>
                          <div class="mt-8 flex gap-3 px-1">
                              <button onclick="document.querySelector('shopify-store').buyNow(event)" class="flex-grow bg-black text-white py-4 rounded-full font-headline font-black text-[10px] uppercase tracking-widest hover:bg-zinc-800 shadow-md">
                                  Buy Now
                              </button>
                              <button onclick="document.getElementById('cart').addLine(event).showModal();" class="w-14 h-14 border-2 border-black rounded-full flex items-center justify-center hover:bg-black hover:text-white transition-all shadow-sm">
                                  <span class="material-symbols-outlined text-[24px]">shopping_bag</span>
                              </button>
                          </div>
                      </div>
                  </template>
              </shopify-list-context>
          </div>
      </div>
  </section>
</main>

<!-- Footer -->
<footer class="bg-[#f4f3f3] text-black w-full pt-24 pb-12 border-t border-black/5">
    <div class="max-w-7xl mx-auto px-6 md:px-12 grid grid-cols-1 md:grid-cols-12 gap-16">
        <div class="md:col-span-4 space-y-6">
            <h4 class="text-3xl font-black tracking-tighter uppercase">{{ section.settings.brand_text | default: "TQS" }}</h4>
            <p class="font-body text-base text-outline leading-relaxed max-w-sm">
                Curated botanical remedies for the modern canvas. Minimalist science, maximalist results.
            </p>
        </div>
        
        <div class="md:col-span-8 grid grid-cols-2 md:grid-cols-3 gap-12">
            <div class="flex flex-col space-y-4">
                <span class="font-label text-xs font-black uppercase tracking-[0.2em] text-outline mb-2">Explore</span>
                {% for link in linklists[section.settings.main_menu].links %}
                    <a class="font-label text-sm font-bold hover:text-outline transition-colors" href="{{ link.url }}">{{ link.title }}</a>
                {% endfor %}
            </div>
            <div class="flex flex-col space-y-4">
                <span class="font-label text-xs font-black uppercase tracking-[0.2em] text-outline mb-2">Policies</span>
                {% for link in linklists[section.settings.footer_menu].links %}
                    <a class="font-label text-sm font-bold hover:text-outline transition-colors" href="{{ link.url }}">{{ link.title }}</a>
                {% endfor %}
            </div>
            <div class="flex flex-col space-y-4">
                <span class="font-label text-xs font-black uppercase tracking-[0.2em] text-outline mb-2">Connect</span>
                <a class="font-label text-sm font-bold hover:text-outline transition-colors" href="#">Instagram</a>
                <a class="font-label text-sm font-bold hover:text-outline transition-colors" href="#">WhatsApp</a>
            </div>
        </div>
    </div>
</footer>

{% schema %}
{
  "name": "TQS Home Storefront",
  "settings": [
    {
      "type": "text",
      "id": "brand_text",
      "label": "Brand Name",
      "default": "Top Quality Store (TQS)"
    },
    {
      "type": "link_list",
      "id": "main_menu",
      "label": "Header Menu",
      "default": "main-menu"
    },
    {
      "type": "link_list",
      "id": "footer_menu",
      "label": "Footer Menu",
      "default": "footer"
    }
  ],
  "presets": [
    {
      "name": "TQS Home Storefront"
    }
  ]
}
{% endschema %}
