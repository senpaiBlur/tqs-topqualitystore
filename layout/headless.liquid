<!DOCTYPE html>
<html class="light" lang="en">
<head>
  <meta charset="utf-8"/>
  <meta content="width=device-width, initial-scale=1.0" name="viewport"/>
  <title>{{ page_title }}</title>
  
  <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
  <link href="https://fonts.googleapis.com" rel="preconnect"/>
  <link crossorigin="" href="https://fonts.gstatic.com" rel="preconnect"/>
  <link href="https://fonts.googleapis.com/css2?family=Be+Vietnam+Pro:wght@400;600;700;900&family=Lexend:wght@300;400;500&family=Public+Sans:wght@400;500;600&display=swap" rel="stylesheet"/>
  <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet"/>
  
  <script id="tailwind-config">
    tailwind.config = {
        darkMode: "class",
        theme: {
            extend: {
                "colors": {
                    "on-secondary-fixed": "#1b1c1c",
                    "surface": "#faf9f9",
                    "on-secondary-container": "#1b1c1c",
                    "secondary-fixed": "#c8c6c6",
                    "on-tertiary-fixed-variant": "#e2e2e2",
                    "surface-container-highest": "#e3e2e2",
                    "tertiary-fixed-dim": "#474747",
                    "on-surface": "#1a1c1c",
                    "surface-bright": "#faf9f9",
                    "on-primary-fixed": "#ffffff",
                    "primary-container": "#3c3b3b",
                    "inverse-surface": "#2f3131",
                    "outline": "#777777",
                    "on-error-container": "#410002",
                    "primary-fixed": "#5f5e5e",
                    "on-surface-variant": "#474747",
                    "surface-tint": "#5f5e5e",
                    "on-primary-container": "#ffffff",
                    "secondary-fixed-dim": "#acabaa",
                    "on-error": "#ffffff",
                    "secondary-container": "#d6d4d3",
                    "on-tertiary": "#e2e2e2",
                    "on-background": "#1a1c1c",
                    "outline-variant": "#c6c6c6",
                    "on-secondary": "#ffffff",
                    "surface-container-high": "#e9e8e8",
                    "on-secondary-fixed-variant": "#3b3b3b",
                    "error": "#ba1a1a",
                    "on-tertiary-container": "#ffffff",
                    "primary-fixed-dim": "#484646",
                    "surface-dim": "#dadada",
                    "on-primary-fixed-variant": "#e5e2e1",
                    "inverse-primary": "#c9c6c5",
                    "on-primary": "#e5e2e1",
                    "surface-container": "#efeeed",
                    "surface-variant": "#e3e2e2",
                    "tertiary-fixed": "#5e5e5e",
                    "tertiary": "#3b3b3b",
                    "surface-container-lowest": "#ffffff",
                    "surface-container-low": "#f4f3f3",
                    "inverse-on-surface": "#f1f0f0",
                    "error-container": "#ffdad6",
                    "on-tertiary-fixed": "#ffffff",
                    "secondary": "#5f5e5e",
                    "tertiary-container": "#747474",
                    "primary": "#000000",
                    "background": "#faf9f9"
                },
                "borderRadius": {
                    "DEFAULT": "0.25rem",
                    "lg": "0.5rem",
                    "xl": "0.75rem",
                    "full": "9999px"
                },
                "fontFamily": {
                    "headline": ["Be Vietnam Pro", "sans-serif"],
                    "body": ["Lexend", "sans-serif"],
                    "label": ["Public Sans", "sans-serif"]
                }
            },
        },
    }
  </script>
  
  <style>
    .material-symbols-outlined {
        font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
    }
    
    /* Cart Customizations Based on Instructions */
    shopify-cart::part(dialog) {
      border-radius: 0.5rem;
    }
    shopify-cart::part(primary-button) {
      background-color: #000000;
      border: 0;
      border-radius: 0.5rem;
      color: #ffffff;
      font-size: 0.875rem;
      font-weight: 700;
      font-family: "Be Vietnam Pro", sans-serif;
      text-transform: uppercase;
    }
    shopify-cart::part(secondary-button) {
      background-color: #ffffff;
      color: #000;
      fill: #000;
      border: 2px solid #000;
      border-radius: 0.5rem;
    }
  </style>

  <!-- Storefront Web Components Script -->
  <script type="module" src="https://cdn.shopify.com/storefront/web-components.js"></script>
    
  {{ content_for_header }}
</head>
<body class="bg-surface text-on-surface font-body antialiased selection:bg-primary-container selection:text-on-primary-container">
  
  <shopify-store store-domain="tqs-topqualitystore.myshopify.com" public-access-token="aec0f6de7491629c105bbcfb360c6a1a">
    <!-- Global Cart Component (from Storefront API toolkit) -->
    <shopify-cart id="cart"></shopify-cart>
    
    {{ content_for_layout }}
  </shopify-store>

</body>
</html>
