    <style>
        .material-symbols-outlined {
            font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
        }

        /* Cart Customizations - Bottom Sheet Animation */
        shopify-cart::part(dialog) {
            margin: 0;
            margin-top: auto;
            width: 100vw;
            max-width: 100vw;
            height: 90vh;
            max-height: 90vh;
            border-radius: 1.5rem 1.5rem 0 0;
            animation: slideUpCart 0.4s cubic-bezier(0.16, 1, 0.3, 1);
            box-shadow: 0 -10px 40px rgba(0,0,0,0.1);
        }

        @keyframes slideUpCart {
           from { transform: translateY(100%); }
           to { transform: translateY(0); }
        }

        shopify-cart::part(primary-button) {
          background-color: #000000;
          border: 0;
          border-radius: 99px;
          color: #ffffff;
          font-size: 0.875rem;
          font-weight: 700;
          font-family: "Be Vietnam Pro", sans-serif;
          text-transform: uppercase;
          letter-spacing: 0.15em;
          box-shadow: 0 4px 15px rgba(214, 184, 192, 0.3);
        }
        shopify-cart::part(secondary-button) {
          background-color: #ffffff;
          color: #000;
          fill: #000;
          border: 2px solid #000;
          border-radius: 99px;
        }
    </style>
    <script type="module" src="https://cdn.shopify.com/storefront/web-components.js"></script>
    {{ content_for_header }}
</head>
<body class="bg-surface text-on-surface font-body antialiased selection:bg-primary-container selection:text-on-primary-container">
    <shopify-store store-domain="tqs-topqualitystore.myshopify.com" public-access-token="aec0f6de7491629c105bbcfb360c6a1a">
        <shopify-cart id="cart"></shopify-cart>
        {{ content_for_layout }}
    </shopify-store>

    <!-- Bottom Handle -> Mobile Only -->
    <div id="checkout-drawer-handle" class="fixed bottom-0 left-0 w-full z-[45] bg-surface-container-lowest rounded-t-3xl shadow-[0_-4px_30px_rgba(0,0,0,0.08)] cursor-grab touch-none flex flex-col items-center pb-safe transform transition-transform duration-300 md:hidden">
        <div class="w-12 h-1.5 bg-outline-variant/40 rounded-full mt-3 mb-2 pointer-events-none"></div>
        <div class="flex justify-between items-center w-full px-6 pb-4 pt-1 pointer-events-none">
            <div class="font-headline font-bold text-primary flex items-center gap-2">
                <span class="material-symbols-outlined text-[20px]" style="font-variation-settings: 'FILL' 1;">shopping_bag</span>
                <span class="text-sm tracking-tight text-black">Checkout View</span>
            </div>
            <span class="text-[10px] font-label font-bold uppercase tracking-widest text-primary bg-primary/5 px-3 py-1.5 rounded-full flex gap-1 items-center">
               Swipe Up <span class="material-symbols-outlined text-[14px]">expand_less</span>
            </span>
        </div>
    </div>

    <script>
      document.addEventListener("DOMContentLoaded", () => {
          const handle = document.getElementById('checkout-drawer-handle');
          if (!handle) return;
          let startY = 0;
          let currentY = 0;
          let isDragging = false;
          let hasMoved = false;
          
          const handleDragStart = (clientY) => {
              isDragging = true;
              hasMoved = false;
              startY = clientY;
              handle.style.transition = 'none';
          };
          
          const handleDragMove = (clientY) => {
              if (!isDragging) return;
              currentY = clientY;
              const diff = currentY - startY;
              if (diff < -5) hasMoved = true;
              
              if (diff < 0) {
                  handle.style.transform = `translateY(${diff}px)`;
                  if (diff < -40) { // Threshold for swipe up
                      isDragging = false;
                      handle.style.transform = 'translateY(0)';
                      handle.style.transition = 'transform 0.3s';
                      const cart = document.getElementById('cart');
                      if (cart) cart.showModal();
                  }
              }
          };

          const handleDragEnd = () => {
              if (!isDragging) return;
              isDragging = false;
              handle.style.transform = 'translateY(0)';
              handle.style.transition = 'transform 0.3s ease';
          };

          handle.addEventListener('mousedown', (e) => handleDragStart(e.clientY));
          document.addEventListener('mousemove', (e) => handleDragMove(e.clientY));
          document.addEventListener('mouseup', handleDragEnd);

          handle.addEventListener('touchstart', (e) => {
              handleDragStart(e.touches[0].clientY);
          }, {passive: true});

          document.addEventListener('touchmove', (e) => {
              if (isDragging && hasMoved) {
                  if (e.cancelable) e.preventDefault();
                  handleDragMove(e.touches[0].clientY);
              }
          }, {passive: false});

          document.addEventListener('touchend', handleDragEnd);

          handle.addEventListener('click', (e) => {
              if (hasMoved) {
                  e.preventDefault();
                  e.stopPropagation();
                  return;
              }
              const cart = document.getElementById('cart');
              if (cart) cart.showModal();
          });
      });
    </script>
</body>
</html>
