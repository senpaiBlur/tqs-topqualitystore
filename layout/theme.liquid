                        "surface-variant": "#ffffff",
                        "tertiary-fixed": "#5e5e5e",
                        "tertiary": "#3b3b3b",
                        "surface-container-lowest": "#ffffff",
                        "surface-container-low": "#fcfcfc",
                        "inverse-on-surface": "#f8f3f4",
                        "error-container": "#ffdad6",
